# 若木云卡环境变量示例
# 复制为 .env 后用于 scripts/deploy.sh / deploy/docker-compose.prod.yml。

# Runtime
APP_VERSION=ruomu-local
SERVER_MODE=release
LOG_LEVEL=info
APP_TOTP_ISSUER=若木云卡

# Ports
API_PORT=8080
USER_PORT=80
ADMIN_PORT=8081

# Security
# 生产必须替换为 32 位以上强随机字符串。
APP_SECRET_KEY=change-me-32-byte-app-secret-key
JWT_SECRET=change-me-32-byte-admin-jwt-secret
USER_JWT_SECRET=change-me-32-byte-user-jwt-secret

# Bootstrap Admin
# 仅首次初始化空数据库时生效；生产建议首次启动后立即改密。
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeMeAdmin123456

# API
API_BASE_URL=
VITE_API_BASE_URL=

# User Frontend
PUBLIC_SITE_URL=

# Admin Frontend
ADMIN_SITE_URL=
VITE_ADMIN_PATH=

# Database
# 默认使用容器内 SQLite；如切换 PostgreSQL，请同步修改 DATABASE_DRIVER 和 DATABASE_DSN。
DATABASE_DRIVER=sqlite
DATABASE_DSN=/app/db/ruomu.db
DATABASE_URL=

# Redis / Queue
REDIS_PASSWORD=
REDIS_PREFIX=ruomu
REDIS_URL=

# Auth
JWT_EXPIRE_HOURS=24

# Payment
PAYMENT_CALLBACK_URL=

# Upload
UPLOAD_PATH=/app/uploads

# Optional Services
EMAIL_ENABLED=false
CAPTCHA_PROVIDER=none
